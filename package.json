{
  "name": "vn-insurance-fti",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "prisma generate && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "prisma generate && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "faq:import-official": "tsx scripts/import-official-faqs.ts",
    "faq:import-thuvien": "tsx scripts/import-thuvien-tlpl-bhxh-faqs.ts",
    "pdf:ocr-import": "tsx scripts/ocr-import-scanned-pdf.ts",
    "db:d1:apply": "wrangler d1 migrations apply vn-insurance-fti-config --remote"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.9",
    "@prisma/adapter-pg": "^6.19.0",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.12.0",
    "next": "16.2.6",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "prisma": "^6.19.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hyzyla/pdfium": "^2.1.12",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4",
    "wrangler": "^4.90.0"
  }
}
