# PostgreSQL (bắt buộc khi chạy API + Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Tuỳ chọn: giới hạn kết nối pool (mặc định 10)
# PG_POOL_MAX=10

# Email HR (form Hỏi HR / ticket) — không commit giá trị thật
# HR_CONTACT_EMAIL="trangtth39@fpt.com"

# Phiên đăng nhập CMS (/admin) — BẮT BUỘC trên production (wrangler secret put SESSION_SECRET)
# Không dùng chung với CACHE_REVALIDATE_SECRET.
# SESSION_SECRET="generate-a-long-random-string"

# Tỷ lệ NLĐ đóng BH (calculator) — số thập phân 0–1
# BHXH_EMPLOYEE_RATE=0.08
# BHYT_EMPLOYEE_RATE=0.015
# BHTN_EMPLOYEE_RATE=0.01

# Bearer cho POST /api/admin/revalidate-cache và cron Worker
# CACHE_REVALIDATE_SECRET="generate-a-long-random-string"

# Cloudflare Email Service — đặt bằng `wrangler secret put`, không commit
# CLOUDFLARE_EMAIL_API_TOKEN="..."
# CLOUDFLARE_ACCOUNT_ID="your-account-id"
# HR_EMAIL_FROM="noreply@your-verified-domain.com"

# URL Worker (cron gọi lại chính nó) — khớp domain sau deploy
# CRON_WORKER_BASE_URL="https://your-worker.your-subdomain.workers.dev"

# URL công khai (sitemap, metadataBase, OG) — mặc định lấy từ CRON_WORKER_BASE_URL
# NEXT_PUBLIC_SITE_URL="https://your-worker.your-subdomain.workers.dev"

# Rate limit thao tác CMS (duyệt/từ chối văn bản) — tránh Turnstile khi duyệt hàng loạt
# ADMIN_ACTION_RATE_LIMIT_MAX=120
# ADMIN_ACTION_RATE_WINDOW_SEC=600

# Rate limit đăng nhập CMS (mặc định 10 / 15 phút / IP)
# LOGIN_RATE_LIMIT_MAX=10
# LOGIN_RATE_LIMIT_WINDOW_SEC=900

# Rate limit API công khai (search/ask — mặc định 30/phút/IP; ask-hr 5/15 phút)
# PUBLIC_API_RATE_LIMIT_MAX=30
# PUBLIC_API_RATE_LIMIT_WINDOW_SEC=60
# ASK_HR_RATE_LIMIT_MAX=5
# ASK_HR_RATE_LIMIT_WINDOW_SEC=900

# Cloudflare Turnstile — chống bot trên form công khai + đăng nhập CMS
# Tạo widget tại Cloudflare Dashboard → Turnstile → Add site
# Dev/test (luôn pass): site=1x00000000000000000000AA secret=1x0000000000000000000000000000000AA
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Tuỳ chọn: Bearer automation/CI cho POST /api/media/ingest (UI admin dùng session CMS)
# MEDIA_INGEST_TOKEN="..."
# OPENAI_API_KEY="..."
# UNSPLASH_ACCESS_KEY="..."
