generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "queryCompiler"]
  binaryTargets   = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  EMPLOYEE
  HR
  ADMIN
}

enum EmployeeGroup {
  PROBATION
  OFFICIAL
  MANAGER
}

enum DocumentSourceType {
  UPLOAD
  CRAWL
  MANUAL
}

enum DocumentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  ARCHIVED
  EXPIRED
}

enum FaqStatus {
  DRAFT
  APPROVED
  ARCHIVED
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
}

enum CrawlSourceType {
  OFFICIAL
  GOVERNMENT
  LEGAL_DATABASE
  REFERENCE
  NEWS
}

enum CrawlTrustLevel {
  HIGH
  MEDIUM
  LOW
}

enum CrawlFrequency {
  DAILY
  WEEKLY
  MANUAL
}

enum LegalDocumentType {
  LAW
  DECREE
  CIRCULAR
  DECISION
  OFFICIAL_DISPATCH
  GUIDANCE
  NEWS
  OTHER
}

enum CrawlItemStatus {
  NEW
  PENDING_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum LegalUpdateImpactLevel {
  LOW
  MEDIUM
  HIGH
}

enum LegalUpdateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SourceLabelType {
  OFFICIAL_LAW
  INTERNAL_POLICY
  REFERENCE_ARTICLE
  HR_APPROVED
}

enum PublishWorkflowStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_EMPLOYEE
  RESOLVED
  CLOSED
}

enum TicketPriority {
  NORMAL
  URGENT
}

enum CalculatorConfigStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model User {
  id                 String        @id @default(cuid())
  name               String
  email              String        @unique
  passwordHash       String?
  role               UserRole      @default(EMPLOYEE)
  employeeGroup      EmployeeGroup @default(OFFICIAL)
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  questionLogs       QuestionLog[]
  reviewedCrawlItems CrawlItem[]   @relation("CrawlItemReviewer")
  sessions           Session[]
  cmsAuditLogs       CmsAuditLog[]
  assignedTickets    HrTicket[]    @relation("TicketAssignee")
  createdTickets     HrTicket[]    @relation("TicketCreator")
  uploadedMedia      MediaAsset[]
  calculatorConfigs  CalculatorConfig[]
  contentVersions    ContentVersion[]
}

model Category {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  faqs          FAQ[]
  documents     Document[]
  crawlKeywords CrawlKeyword[]
  legalUpdates  LegalUpdate[]
  topicPages    TopicPage[]
}

model FAQ {
  id              String          @id @default(cuid())
  slug            String?         @unique
  question        String
  shortAnswer     String
  detailedAnswer  String?
  eligibility     String?
  benefits        String?
  requiredDocs    String?
  deadlineNote    String?
  steps           Json?
  hrEscalation    String?
  relatedSlugs    Json?
  sourceLabel     SourceLabelType @default(HR_APPROVED)
  previewToken    String?
  categoryId      String?
  category        Category?       @relation(fields: [categoryId], references: [id])
  status          FaqStatus       @default(DRAFT)
  employeeGroup   EmployeeGroup?
  confidenceLevel ConfidenceLevel @default(HIGH)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  citations       Citation[]

  @@index([status])
  @@index([question])
  @@index([slug])
}

model Document {
  id            String             @id @default(cuid())
  title         String
  fileName      String?
  fileType      String?
  sourceType    DocumentSourceType @default(UPLOAD)
  status        DocumentStatus     @default(DRAFT)
  version       Int                @default(1)
  effectiveDate DateTime?
  expiryDate    DateTime?
  categoryId    String?
  category      Category?          @relation(fields: [categoryId], references: [id])
  storagePath   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  chunks        DocumentChunk[]
  citations     Citation[]

  @@index([status])
}

model DocumentChunk {
  id         String     @id @default(cuid())
  documentId String
  document   Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String
  chunkIndex Int
  /// Optional embedding vector for pgvector / external ANN later; mock search can ignore or use.
  embedding  Json?
  metadata   Json?
  createdAt  DateTime   @default(now())
  citations  Citation[]

  @@index([documentId])
}

model Citation {
  id              String         @id @default(cuid())
  faqId           String?
  faq             FAQ?           @relation(fields: [faqId], references: [id], onDelete: Cascade)
  documentId      String?
  document        Document?      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentChunkId String?
  chunk           DocumentChunk? @relation(fields: [documentChunkId], references: [id], onDelete: SetNull)
  title           String
  sourceUrl       String?
  legalArticle    String?
  legalClause     String?
  effectiveDate   DateTime?
}

model QuestionLog {
  id                 String           @id @default(cuid())
  userId             String?
  user               User?            @relation(fields: [userId], references: [id])
  question           String
  normalizedQuestion String?
  answer             String?
  confidenceLevel    ConfidenceLevel?
  needsHrReview      Boolean          @default(false)
  resultCount        Int?
  hasAnswer          Boolean?
  noResult           Boolean          @default(false)
  categorySlug       String?
  createdAt          DateTime         @default(now())
  hrTicket           HrTicket?

  @@index([createdAt])
  @@index([noResult])
}

model CrawlSource {
  id             String          @id @default(cuid())
  name           String
  baseUrl        String
  domain         String
  sourceType     CrawlSourceType @default(OFFICIAL)
  trustLevel     CrawlTrustLevel @default(HIGH)
  active         Boolean         @default(true)
  crawlFrequency CrawlFrequency  @default(WEEKLY)
  lastCrawledAt  DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  items          CrawlItem[]

  @@unique([domain, baseUrl])
  @@index([active])
  @@index([domain])
}

model CrawlKeyword {
  id         String    @id @default(cuid())
  keyword    String    @unique
  active     Boolean   @default(true)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([active])
}

model CrawlItem {
  id                String             @id @default(cuid())
  sourceId          String
  source            CrawlSource        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  title             String
  url               String
  canonicalUrl      String             @unique
  domain            String
  contentText       String
  rawHtml           String?
  summary           String?
  detectedTopics    Json?
  detectedKeywords  Json?
  legalDocumentType LegalDocumentType?
  documentNumber    String?
  issuedDate        DateTime?
  effectiveDate     DateTime?
  expiryDate        DateTime?
  status            CrawlItemStatus    @default(PENDING_REVIEW)
  reviewNote        String?
  reviewedById      String?
  reviewedBy        User?              @relation("CrawlItemReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt        DateTime?
  publishedAt       DateTime?
  duplicateOfId     String?
  duplicateOf       CrawlItem?         @relation("CrawlItemDuplicate", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates        CrawlItem[]        @relation("CrawlItemDuplicate")
  contentHash       String
  crawledAt         DateTime           @default(now())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  legalUpdate       LegalUpdate?

  @@index([sourceId])
  @@index([status])
  @@index([status, crawledAt(sort: Desc)])
  @@index([contentHash])
  @@index([domain])
  @@index([crawledAt])
}

model LegalUpdate {
  id                String                 @id @default(cuid())
  crawlItemId       String                 @unique
  crawlItem         CrawlItem              @relation(fields: [crawlItemId], references: [id], onDelete: Cascade)
  title             String
  slug              String                 @unique
  summary           String?
  body              String
  sourceUrl         String
  sourceName        String
  categoryId        String?
  category          Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  legalDocumentType LegalDocumentType?
  documentNumber    String?
  issuedDate        DateTime?
  effectiveDate     DateTime?
  publishedAt       DateTime?
  impactLevel       LegalUpdateImpactLevel @default(MEDIUM)
  affectedGroups    Json?
  hrActionRequired  Boolean                @default(false)
  hrActionSummary   String?
  status            LegalUpdateStatus      @default(DRAFT)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([status])
  @@index([status, publishedAt(sort: Desc)])
  @@index([publishedAt])
  @@index([legalDocumentType])
}

model ReviewAuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  oldStatus  String?
  newStatus  String?
  note       String?
  actorId    String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model HrTicket {
  id              String         @id @default(cuid())
  ticketNumber    String         @unique
  question        String
  detail          String?
  topic           String?
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(NORMAL)
  replyEmail      String
  searchQuery     String?
  notifyEmailSent Boolean        @default(false)
  assigneeId      String?
  assignee        User?          @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById     String?
  createdBy       User?          @relation("TicketCreator", fields: [createdById], references: [id], onDelete: SetNull)
  questionLogId   String?        @unique
  questionLog     QuestionLog?   @relation(fields: [questionLogId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  resolvedAt      DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([ticketNumber])
}

model TopicPage {
  id          String                @id @default(cuid())
  slug        String                @unique
  title       String
  description String
  heroSummary String?
  categoryId  String?
  category    Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  status      PublishWorkflowStatus @default(DRAFT)
  sortOrder   Int                   @default(0)
  previewToken String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([status])
}

model CalculatorConfig {
  id            String                 @id @default(cuid())
  key           String
  name          String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  formulaJson   Json
  status        CalculatorConfigStatus @default(DRAFT)
  version       Int                    @default(1)
  createdById   String?
  createdBy     User?                  @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([key, status])
  @@index([effectiveFrom])
}

model ContentVersion {
  id          String                @id @default(cuid())
  entityType  String
  entityId    String
  version     Int
  snapshot    Json
  status      PublishWorkflowStatus
  publishedAt DateTime?
  createdById String?
  createdBy   User?                 @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime              @default(now())

  @@unique([entityType, entityId, version])
  @@index([entityType, entityId])
}

model CmsAuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actorId])
}

model MediaAsset {
  id           String   @id @default(cuid())
  storageKey   String   @unique
  fileName     String
  mimeType     String
  sizeBytes    Int
  isInternal   Boolean  @default(true)
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([isInternal])
}

model ChecklistTemplate {
  id          String                @id @default(cuid())
  title       String
  slug        String                @unique
  description String?
  items       Json
  topicSlug   String?
  status      PublishWorkflowStatus @default(DRAFT)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([status])
  @@index([topicSlug])
}
